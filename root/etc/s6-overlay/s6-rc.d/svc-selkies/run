#!/usr/bin/with-contenv bash

export XCURSOR_THEME=Breeze_Light

# Default sink setup
if [ ! -f '/dev/shm/audio.lock' ]; then
  until [ -f /defaults/pid ]; do
    sleep .5
  done
  s6-setuidgid abc with-contenv pactl \
    load-module module-null-sink \
    sink_name="output" \
    sink_properties=device.description="output"
  s6-setuidgid abc with-contenv pactl \
    load-module module-null-sink \
    sink_name="input" \
    sink_properties=device.description="input"
  touch /dev/shm/audio.lock
fi

# Setup dev mode if defined
if [ ! -z ${DEV_MODE+x} ]; then
  # Dev deps
  dnf install -y nodejs
  npm install -g nodemon
  rm -Rf $HOME/.npm
  if [[ "${DEV_MODE}" == "pixelflux" ]]; then
    # Dev deps
    dnf install -y \
      cargo \
      clang \
      cmake \
      curl \
      gcc-c++ \
      gcc \
      git \
      ffmpeg-devel \
      libdrm-devel \
      libev-devel \
      mesa-libgbm-devel \
      libinput-devel \
      libjpeg-turbo-devel \
      pixman-devel \
      systemd-devel \
      libva-devel \
      wayland-devel \
      libX11-devel \
      x264-devel \
      libXcomposite-devel \
      libXcursor-devel \
      libXext-devel \
      libXfixes-devel \
      libxkbcommon-devel \
      libyuv-devel \
      make \
      nasm \
      python3-devel \
      python3-pip \
      python3-setuptools \
      python3-setuptools-rust \
      python3-wheel \
      rust
    # Run backend watcher
    chown -R abc:abc /lsiopy
    cd /config/src
    s6-setuidgid abc \
      nodemon \
      --watch . \
      --ext py,cpp,h,c,rs,toml \
      --ignore "pixelflux_wayland/target/" \
      --ignore "build/" \
      --ignore "*.egg-info/" \
      --ignore "__pycache__/" \
      --exec "pip uninstall -y pixelflux || true && CPATH='/usr/include/ffmpeg' pip install . --break-system-packages && (killall labwc || true) && (killall selkies-desktop || true) && cd /tmp && python3 -m selkies --addr='localhost' --mode='websockets' --debug='true'"
  else
    # Frontend setup
    if [[ "${DEV_MODE}" == "core" ]]; then
      # Core just runs from directory
      cd $HOME/src/addons/selkies-web-core
      s6-setuidgid abc npm install
      s6-setuidgid abc npm run serve &
    else
      # Build core
      cd $HOME/src/addons/selkies-web-core
      s6-setuidgid abc npm install
      s6-setuidgid abc npm run build
      s6-setuidgid abc cp dist/selkies-core.js ../${DEV_MODE}/src/
      s6-setuidgid abc nodemon \
        --watch . \
        --ext js,html \
        --ignore dist/ \
        --ignore node_modules/ \
        --exec "npm run build && cp dist/selkies-core.js ../${DEV_MODE}/src/" &
      # Copy touch gamepad
      s6-setuidgid abc cp ../universal-touch-gamepad/universalTouchGamepad.js ../${DEV_MODE}/src/
      s6-setuidgid abc nodemon \
        --watch ../universal-touch-gamepad/universalTouchGamepad.js \
        --exec "cp ../universal-touch-gamepad/universalTouchGamepad.js ../${DEV_MODE}/src/" &
      # Copy themes
      s6-setuidgid abc cp -a nginx ../${DEV_MODE}/
      # Run passed frontend
      cd $HOME/src/addons/${DEV_MODE}
      s6-setuidgid abc npm install
      s6-setuidgid abc npm run serve &
    fi
    # Run backend
    cd $HOME/src/src
    s6-setuidgid abc \
      nodemon -V --ext py --watch . --exec \
        "killall labwc || true; killall selkies-desktop || true; python3 -m selkies --addr='localhost' --mode='websockets' --debug='true'"
  fi
fi

# Start Selkies
GBM_BACKENDS_PATH=/usr/lib/x86_64-linux-gnu/gbm
export GBM_BACKEND=nvidia-drm
exec s6-setuidgid abc \
  selkies \
    --addr="localhost" \
    --mode="websockets"
